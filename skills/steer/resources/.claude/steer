#!/bin/bash
# steer — queue a mid-run steering message for THIS project's Claude Code session.
#
# Usage (from a SECOND terminal, while Claude is working):
#   ./.claude/steer "pivot to the simpler approach — don't refactor the parser yet"
#
# The inbox is resolved relative to THIS script (which lives at <project>/.claude/steer),
# so it works regardless of the caller's cwd — no global PATH entry, no env var needed.
# The PreToolUse `steer-inject` hook injects the message at Claude's next tool call.
#
# Concatenate-in-order via O_APPEND: each `>>` write lands intact and ordered, so
# multiple steers before a tool boundary are merged, not dropped. (Atomic up to
# PIPE_BUF, ~4KB, on a local filesystem — fine for short human-typed messages.)

HERE="$(cd "$(dirname "$0")" && pwd)"   # <project>/.claude
INBOX="$HERE/steer-inbox"

MSG="$*"
if [ -z "$MSG" ]; then
  echo 'steer: usage: ./.claude/steer "your message"' >&2
  exit 1
fi

printf '%s\n' "$MSG" >> "$INBOX"
echo "steer: queued (delivers at Claude's next tool call)." >&2
