<!--
character-sheet-web.html.template — full (web) character sheet for the brand-workshop mascot lane
Derived from a tested reference build (v0.3, 2026-07-07). Token syntax: UPPER_SNAKE names
wrapped in double curly braces. Fill via string replace ONLY (never str.format — see D10;
the instantiated output must contain no leftover double-open-brace pairs).

FONT TOKENS      {{FONTS_HREF}} Google Fonts stylesheet URL for the three families below
                 {{FONT_DISPLAY}} {{FONT_BODY}} {{FONT_MONO}}
COLOR TOKENS     {{C_BG}} page bg · {{C_SURFACE}} card bg · {{C_GROUND}} brand ground tint ·
                 {{C_GROUND2}} deeper ground · {{C_INK}} text · {{C_INK2}} secondary · {{C_MUTED}} hints ·
                 {{C_BRAND}} brand dark (bands) · {{C_BRAND_DEEP}} display headings ·
                 {{C_ACCENT}} energy fills · {{C_ACCENT_INK}} AA text-safe accent · {{C_ACCENT_HOVER}} ·
                 {{C_ON_ACCENT}} text on accent · {{C_SPARK}} rare highlight · {{C_SPARK_INK}} links/focus ·
                 {{C_SOFT}} soft accent · {{C_BORDER}} hairlines ·
                 {{C_DOT}} hero dot rgba · {{C_STAMP_BG}} stamp fill rgba ·
                 {{C_CHECKER_A}} {{C_CHECKER_B}} transparency checker · {{C_BAR_DOT}} browser-chrome dots ·
                 {{C_BAND_MUTED}} {{C_BAND_NUM}} {{C_BAND_TEXT}} {{C_BAND_TRACK}} stats-band ramp
CONTENT TOKENS   {{KICKER}} {{NAME_MAIN}} {{NAME_SUB}} {{TAGLINE}} {{STAMP_LINES}}
                 {{T_IDENTITY}} {{IDENTITY_ROWS}} {{T_STORY}} {{STORY_MAIN}} {{STORY_ASIDE_LABEL}} {{STORY_ASIDE}}
                 {{T_STATS}} {{STATS_ROWS}} {{T_TRAITS}} {{TRAIT_ITEMS}} {{T_POSES}} {{POSE_TILES}} {{POSE_GHOST}}
                 {{T_USAGE}} {{MOCK_BRAND}} {{MOCK_H}} {{MOCK_P}} {{MOCK_CTA}} {{CHAT_NAME}} {{CHAT_MSG}}
                 {{DARK_NOTE}} {{COVER_H}} {{COVER_SUB}} {{COVER_URL}}
                 {{T_PALETTE}} {{RATIO_SEGMENTS}} {{CHIPS}} {{PALETTE_RULES}}
                 {{T_PROPS}} {{TYPE_SPECIMEN}} {{VOICE_YES_ITEMS}} {{VOICE_NO_ITEMS}} {{USAGE_RULE_ITEMS}} {{RECIPE_PRE}}
                 {{FOOTER_L}} {{FOOTER_R}} {{PAGE_TITLE}} {{META_DESC}} {{LANG}}
IMAGE TOKENS     {{MASTER_B64}} {{HEAD_B64}} (base64 PNG, no data: prefix)
NOTE             The dark demo panel colors are intentionally literal (#26272A family): it demonstrates
                 the asset on a universal dark surface, not a brand surface.
ROW/TILE SHAPES  IDENTITY_ROWS: <div class="idrow"><span class="lbl">L</span><span class="dots"></span><span class="val">V</span></div>
                 STATS_ROWS: <div class="stat"><div class="stat-top"><span>L</span><span class="n">9/10</span></div><div class="track"><div class="fill" style="--w:90%;animation-delay:.0s"></div></div></div>
                 POSE_TILES: <div class="pose[ canon]"><div class="ck"><img src="data:image/png;base64,..." alt="L"></div><div class="cap">L<small>TAG</small></div></div>
                 CHIPS: <div class="chip"><div class="sw" style="background:#HEX"></div><div class="cx"><span class="mono">#HEX</span>role</div></div>
                 RATIO_SEGMENTS: <div style="width:50%;background:#HEX;color:#HEX">label 50</div>
-->
<!doctype html>
<html lang="{{LANG}}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{META_DESC}}">
<title>{{PAGE_TITLE}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="{{FONTS_HREF}}" rel="stylesheet">
<style>
:root{
--bg:{{C_BG}};--surface:{{C_SURFACE}};--ground:{{C_GROUND}};--ground-2:{{C_GROUND2}};
--ink:{{C_INK}};--ink-2:{{C_INK2}};--muted:{{C_MUTED}};
--brand:{{C_BRAND}};--brand-deep:{{C_BRAND_DEEP}};
--accent:{{C_ACCENT}};--accent-ink:{{C_ACCENT_INK}};--spark:{{C_SPARK}};--spark-ink:{{C_SPARK_INK}};--soft:{{C_SOFT}};
--border:{{C_BORDER}};--r-lg:22px;--r-md:12px;--r-sm:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'{{FONT_BODY}}',sans-serif;font-weight:400;font-size:16px;line-height:1.75;
background:var(--bg);color:var(--ink)}
h1,h2,h3{font-family:'{{FONT_DISPLAY}}',sans-serif;font-weight:500;line-height:1.22;text-wrap:balance}
.wrap{max-width:1100px;margin:0 auto;padding:0 clamp(20px,4vw,36px)}
.mono{font-family:'{{FONT_MONO}}',monospace;font-size:11.5px;letter-spacing:.07em;color:var(--muted)}
img{display:block;max-width:100%}
section{margin-top:clamp(64px,8vw,104px)}
h2{font-size:clamp(26px,3.4vw,34px);margin-bottom:22px}
h2 .en{font-family:'{{FONT_BODY}}',sans-serif;font-weight:400;font-size:.45em;color:var(--muted);
letter-spacing:.12em;text-transform:uppercase;margin-left:12px;vertical-align:middle}
.prose{max-width:66ch;text-wrap:pretty}

.hero{background:var(--ground);border-radius:var(--r-lg);margin-top:28px;
background-image:radial-gradient({{C_DOT}} 1.4px,transparent 1.4px);background-size:26px 26px;
padding:clamp(28px,5vw,56px) clamp(24px,5vw,60px) 0;
display:grid;grid-template-columns:1.15fr .85fr;gap:28px;align-items:end}
.hero h1{font-size:clamp(52px,8vw,88px);font-weight:600;letter-spacing:-.015em;color:var(--brand-deep)}
.hero .sub{font-family:'{{FONT_DISPLAY}}',sans-serif;font-size:clamp(17px,2vw,21px);color:var(--ink-2);margin-top:2px}
.hero .left{padding-bottom:clamp(30px,5vw,54px)}
.tagline{display:inline-block;margin-top:20px;border:1.5px solid var(--accent-ink);color:var(--accent-ink);
border-radius:999px;padding:6px 18px;font-family:'{{FONT_DISPLAY}}',sans-serif;font-size:14.5px}
.hero .art{margin-bottom:-58px;justify-self:center}
.hero .art img{width:min(380px,100%)}

.idcard{position:relative;background:var(--surface);border:1px solid var(--border);
border-radius:var(--r-lg);padding:clamp(24px,4vw,40px);margin-top:86px}
.idrow{display:flex;align-items:baseline;gap:12px;padding:7px 0}
.idrow .lbl{flex:none;width:128px;font-family:'{{FONT_MONO}}',monospace;font-size:11px;
letter-spacing:.07em;color:var(--muted)}
.idrow .dots{flex:1;border-bottom:2px dotted var(--border);transform:translateY(-5px);min-width:24px}
.idrow .val{flex:none;max-width:62%;font-weight:500;font-size:15.5px;text-align:right}
.stamp{position:absolute;top:-34px;right:26px;width:118px;height:118px;border:2.5px solid var(--accent-ink);
border-radius:50%;display:grid;place-items:center;transform:rotate(-9deg);
background:{{C_STAMP_BG}};color:var(--accent-ink)}
.stamp .ring{width:100px;height:100px;border:1.5px dashed var(--accent-ink);border-radius:50%;
display:grid;place-content:center;text-align:center;font-family:'{{FONT_DISPLAY}}',sans-serif;
font-size:11.5px;line-height:1.5;letter-spacing:.06em}

.story{display:grid;grid-template-columns:1.55fr 1fr;gap:26px;align-items:start}
.story .th-aside{background:var(--ground);border-radius:var(--r-md);padding:26px 28px;font-size:15.5px}
.story .th-aside .k{font-family:'{{FONT_DISPLAY}}',sans-serif;color:var(--accent-ink);font-size:13px;margin-bottom:8px}

.stats-band{background:var(--brand);border-radius:var(--r-lg);color:var(--ground);
padding:clamp(30px,5vw,52px) clamp(24px,5vw,56px);
display:grid;grid-template-columns:1.05fr .95fr;gap:clamp(28px,4vw,56px)}
.stats-band h2{color:var(--ground);margin-bottom:26px}
.stats-band h2 .en{color:{{C_BAND_MUTED}}}
.stat{margin-bottom:19px}
.stat-top{display:flex;justify-content:space-between;align-items:baseline;font-size:14.5px;margin-bottom:7px}
.stat-top .n{font-family:'{{FONT_MONO}}',monospace;font-size:12px;font-variant-numeric:tabular-nums;color:{{C_BAND_NUM}}}
.track{height:10px;background:{{C_BAND_TRACK}};border-radius:99px;overflow:hidden}
.fill{height:100%;background:var(--accent);border-radius:99px;width:var(--w);
animation:grow .9s cubic-bezier(.22,1,.36,1) both}
@keyframes grow{from{width:0}}
.traits{list-style:none;display:grid;gap:14px;font-size:15px;color:{{C_BAND_TEXT}}}
.traits li{padding-left:22px;position:relative}
.traits li::before{content:"◆";position:absolute;left:0;color:var(--accent);font-size:11px;top:5px}

.poses{display:grid;grid-template-columns:1.35fr 1fr 1fr;grid-template-rows:auto auto;gap:16px}
.pose{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);
padding:16px;text-align:center;transition:transform .2s cubic-bezier(.22,1,.36,1)}
.pose:hover{transform:translateY(-4px)}
.pose.canon{grid-row:1/3;display:flex;flex-direction:column;justify-content:center}
.pose .ck{background-color:{{C_CHECKER_A}};border-radius:var(--r-sm);
background-image:linear-gradient(45deg,{{C_CHECKER_B}} 25%,transparent 25%,transparent 75%,{{C_CHECKER_B}} 75%),
linear-gradient(45deg,{{C_CHECKER_B}} 25%,transparent 25%,transparent 75%,{{C_CHECKER_B}} 75%);
background-size:20px 20px;background-position:0 0,10px 10px;padding:14px}
.pose .cap{margin-top:10px;font-family:'{{FONT_DISPLAY}}',sans-serif;font-size:14px}
.pose .cap small{display:block;font-family:'{{FONT_MONO}}',monospace;font-size:10.5px;
letter-spacing:.07em;color:var(--muted);margin-top:2px}
.pose.ghost{border-style:dashed;display:grid;place-content:center;color:var(--muted);
font-family:'{{FONT_MONO}}',monospace;font-size:11.5px;line-height:2;text-align:center}

.browser{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);overflow:hidden}
.browser .bar{background:var(--ground-2);padding:10px 18px;display:flex;gap:7px;align-items:center}
.browser .bar i{width:10px;height:10px;border-radius:50%;background:{{C_BAR_DOT}}}
.browser .bar span{margin-left:12px}
.mock-hero{padding:clamp(26px,4vw,44px) clamp(24px,5vw,52px);display:grid;
grid-template-columns:1.35fr 1fr;gap:24px;align-items:center}
.mock-hero .brand{font-family:'{{FONT_DISPLAY}}',sans-serif;font-weight:500;font-size:15px;color:var(--accent-ink);margin-bottom:12px}
.mock-hero .h{font-family:'{{FONT_DISPLAY}}',sans-serif;font-weight:600;font-size:clamp(26px,3.5vw,36px);line-height:1.3}
.mock-hero p{color:var(--muted);margin:10px 0 22px;font-size:15px;max-width:44ch}
.cta{display:inline-block;background:var(--accent);color:{{C_ON_ACCENT}};font-family:'{{FONT_DISPLAY}}',sans-serif;
font-weight:500;padding:12px 28px;border-radius:12px;transition:background .2s,transform .12s;cursor:default}
.cta:hover{background:{{C_ACCENT_HOVER}}}
.cta:active{transform:translateY(1px)}
.usage-row{display:grid;grid-template-columns:1.2fr .8fr;gap:16px;margin-top:16px}
.panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);padding:24px}
.panel .ph{font-family:'{{FONT_MONO}}',monospace;font-size:11px;letter-spacing:.07em;
color:var(--muted);margin-bottom:18px}
.av-row{display:flex;align-items:flex-end;gap:18px;margin-bottom:22px}
.av{border-radius:50%;background:var(--ground);border:1px solid var(--border)}
.chat{display:flex;gap:12px;align-items:center;border:1px solid var(--border);border-radius:var(--r-md);padding:12px 14px}
.dark-panel{background:#26272A;border:1px solid #3A3B3E;border-radius:var(--r-md);
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:14px;padding:24px}
.dark-panel .ph{color:#9A9B9D;margin-bottom:0}
.cover{margin-top:16px;background:var(--surface);border:1px solid var(--border);
border-radius:var(--r-lg);overflow:hidden}
.cover .inner{aspect-ratio:1200/630;background:var(--ground);display:grid;
grid-template-columns:1.4fr 1fr;align-items:center;padding:0 clamp(24px,5vw,52px);gap:12px}
.cover .h{font-family:'{{FONT_DISPLAY}}',sans-serif;font-weight:600;font-size:clamp(26px,4vw,40px);line-height:1.3}
.cover img{align-self:end;justify-self:center;width:min(300px,100%)}

.ratio{display:flex;height:58px;border-radius:var(--r-md);overflow:hidden;margin-bottom:14px}
.ratio div{display:grid;place-content:center;font-family:'{{FONT_MONO}}',monospace;font-size:11px}
.chips{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-top:18px}
.chip{border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;background:var(--surface)}
.chip .sw{height:58px}
.chip .cx{padding:10px 12px;font-size:12.5px;color:var(--muted)}
.chip .cx .mono{display:block;color:var(--ink-2)}
.rules{margin-top:18px;font-size:14.5px;color:var(--ink-2);max-width:75ch}

.props{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.spec .big{font-family:'{{FONT_DISPLAY}}',sans-serif;font-weight:600;font-size:52px;line-height:1.15;color:var(--brand-deep)}
.spec p{font-size:14.5px;color:var(--ink-2);margin-top:10px}
.voice{display:grid;grid-template-columns:1fr 1fr;gap:16px;font-size:14.5px}
.voice ul{list-style:none;display:grid;gap:9px;align-content:start}
.voice .yes li::before{content:"✓ ";color:var(--accent-ink);font-weight:600}
.voice .no li{color:var(--muted)}
.voice .no li::before{content:"✕ ";font-weight:600}
pre.recipe{font-family:'{{FONT_MONO}}',monospace;font-size:11.5px;line-height:1.85;
white-space:pre-wrap;background:var(--ground);border-radius:var(--r-md);padding:22px 24px;color:var(--ink-2)}

footer{margin-top:clamp(70px,9vw,110px);border-top:1px solid var(--border);
padding:20px 0 44px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px}
a{color:var(--spark-ink)}
:focus-visible{outline:3px solid var(--spark);outline-offset:2px}
@media (prefers-reduced-motion:reduce){
.fill{animation:none}.pose,.cta{transition:none}html{scroll-behavior:auto}}
@media (max-width:820px){
.hero,.story,.stats-band,.mock-hero,.usage-row,.props,.voice{grid-template-columns:1fr}
.poses{grid-template-columns:1fr 1fr}.pose.canon{grid-row:auto;grid-column:1/3}
.hero .art{margin-bottom:0}.idcard{margin-top:70px}
.idrow .val{max-width:56%}.cover .inner{grid-template-columns:1fr;padding:24px}.cover img{display:none}}
</style>
</head>
<body>
<div class="wrap">

<header class="hero">
  <div class="left">
    <div class="mono">{{KICKER}}</div>
    <h1>{{NAME_MAIN}}</h1>
    <div class="sub">{{NAME_SUB}}</div>
    <span class="tagline">{{TAGLINE}}</span>
  </div>
  <div class="art">
    <img src="data:image/png;base64,{{MASTER_B64}}" alt="{{NAME_SUB}}">
  </div>
</header>

<div class="idcard">
  <div class="stamp" aria-hidden="true"><div class="ring">{{STAMP_LINES}}</div></div>
  <h2>{{T_IDENTITY}}</h2>
  {{IDENTITY_ROWS}}
</div>

<section>
  <h2>{{T_STORY}}</h2>
  <div class="story">
    <div class="prose">{{STORY_MAIN}}</div>
    <aside class="th-aside">
      <div class="k">{{STORY_ASIDE_LABEL}}</div>
      {{STORY_ASIDE}}
    </aside>
  </div>
</section>

<section class="stats-band">
  <div>
    <h2>{{T_STATS}}</h2>
    {{STATS_ROWS}}
  </div>
  <div>
    <h2>{{T_TRAITS}}</h2>
    <ul class="traits">{{TRAIT_ITEMS}}</ul>
  </div>
</section>

<section>
  <h2>{{T_POSES}}</h2>
  <div class="poses">
    {{POSE_TILES}}
    <div class="pose ghost">{{POSE_GHOST}}</div>
  </div>
</section>

<section>
  <h2>{{T_USAGE}}</h2>

  <div class="browser">
    <div class="bar"><i></i><i></i><i></i><span class="mono">WEBSITE · HERO</span></div>
    <div class="mock-hero">
      <div>
        <div class="brand">{{MOCK_BRAND}}</div>
        <div class="h">{{MOCK_H}}</div>
        <p>{{MOCK_P}}</p>
        <span class="cta">{{MOCK_CTA}}</span>
      </div>
      <img src="data:image/png;base64,{{MASTER_B64}}" alt="Mascot in a website hero mockup" style="width:min(240px,100%);justify-self:center">
    </div>
  </div>

  <div class="usage-row">
    <div class="panel">
      <div class="ph">AVATAR · 96 / 48 / 32</div>
      <div class="av-row">
        <img class="av" src="data:image/png;base64,{{HEAD_B64}}" width="96" height="96" alt="Mascot avatar at 96 pixels">
        <img class="av" src="data:image/png;base64,{{HEAD_B64}}" width="48" height="48" alt="Mascot avatar at 48 pixels">
        <img class="av" src="data:image/png;base64,{{HEAD_B64}}" width="32" height="32" alt="Mascot avatar at 32 pixels">
      </div>
      <div class="chat">
        <img class="av" src="data:image/png;base64,{{HEAD_B64}}" width="44" height="44" alt="">
        <div style="font-size:14px"><strong>{{CHAT_NAME}}</strong><br>
        <span style="color:var(--muted)">{{CHAT_MSG}}</span></div>
      </div>
    </div>
    <div class="dark-panel">
      <img src="data:image/png;base64,{{MASTER_B64}}" style="width:160px" alt="Mascot on a dark surface">
      <div class="ph mono" style="color:#9A9B9D">{{DARK_NOTE}}</div>
    </div>
  </div>

  <div class="cover">
    <div class="bar" style="background:var(--ground-2);padding:10px 18px"><span class="mono">SOCIAL COVER · 1200×630</span></div>
    <div class="inner">
      <div>
        <div class="h">{{COVER_H}}</div>
        <div style="color:var(--ink-2);margin-top:10px;font-size:15px">{{COVER_SUB}}</div>
        <div class="mono" style="margin-top:18px;color:var(--accent-ink)">{{COVER_URL}}</div>
      </div>
      <img src="data:image/png;base64,{{MASTER_B64}}" alt="Mascot on the social cover">
    </div>
  </div>
</section>

<section>
  <h2>{{T_PALETTE}}</h2>
  <div class="ratio" aria-label="Palette usage ratio">{{RATIO_SEGMENTS}}</div>
  <div class="chips">{{CHIPS}}</div>
  <p class="rules">{{PALETTE_RULES}}</p>
</section>

<section>
  <h2>{{T_PROPS}}</h2>
  <div class="props">
    <div class="panel spec">
      <div class="ph">TYPOGRAPHY</div>
      {{TYPE_SPECIMEN}}
    </div>
    <div class="panel">
      <div class="ph">VOICE — DO / DON'T</div>
      <div class="voice">
        <ul class="yes">{{VOICE_YES_ITEMS}}</ul>
        <ul class="no">{{VOICE_NO_ITEMS}}</ul>
      </div>
    </div>
    <div class="panel">
      <div class="ph">MASCOT USAGE</div>
      <ul class="traits" style="color:var(--ink-2)">{{USAGE_RULE_ITEMS}}</ul>
    </div>
    <div>
      <div class="ph mono" style="margin-bottom:12px">MASCOT RECIPE — mascot.md</div>
      <pre class="recipe">{{RECIPE_PRE}}</pre>
    </div>
  </div>
</section>

<footer>
  <span class="mono">{{FOOTER_L}}</span>
  <span class="mono">{{FOOTER_R}}</span>
</footer>

</div>
</body>
</html>
